[gcode_macro CUT_FILAMENT]
description: Cuts the filament
gcode:
    HOME_IF_NEEDED
    
    {% if printer.gcode_move.position.y < 20 %}
      G1 Y40 F9000
    {% endif %}
    {% if printer.gcode_move.position.y > 300 %}
      G1 Y300 F9000
    {% endif %}
    G1 X305 Y40 F9000
    G1 Y20 F9000
    G1 Y5 F3000
    G4 P500
    G1 Y20 F9000
    G1 Y5 F3000
    G4 P500
    G1 Y20 F9000